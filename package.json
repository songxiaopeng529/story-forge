{
  "name": "story-forge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "predev": "corepack pnpm --filter '@story-forge/desktop^...' build",
    "dev": "corepack pnpm --filter @story-forge/desktop dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  }
}
